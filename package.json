{
  "name": "@soft-kit/core",
  "version": "0.1.0",
  "description": "A framework-agnostic component library with loose Tailwind coupling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js",
      "require": "./dist/components/button/index.cjs"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js",
      "require": "./dist/components/input/index.cjs"
    },
    "./sidebar": {
      "types": "./dist/components/sidebar/index.d.ts",
      "import": "./dist/components/sidebar/index.js",
      "require": "./dist/components/sidebar/index.cjs"
    },
    "./dropdown": {
      "types": "./dist/components/dropdown/index.d.ts",
      "import": "./dist/components/dropdown/index.js",
      "require": "./dist/components/dropdown/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "registry": "node scripts/generate-registry.js",
    "build:cli": "npm run registry && cd cli && npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ui",
    "components",
    "tailwind",
    "design-system"
  ],
  "author": "mainak58",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mainak58/soft-kit.git"
  },
  "homepage": "https://github.com/mainak58/soft-kit#readme",
  "bugs": {
    "url": "https://github.com/mainak58/soft-kit/issues"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "lucide-react": "^0.456.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
